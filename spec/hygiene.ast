  ATMOSPHERE: (1091..1171) "; ── Hygiene proof ─────────────────────────────────────────────────────────────"
  ATMOSPHERE: (1171..1172) "\n"
  ATMOSPHERE: (1172..1173) ";"
  ATMOSPHERE: (1173..1174) "\n"
  ATMOSPHERE: (1174..1250) "; If expansion were naive (non-hygienic), `(my-or #f temp)` would expand to:"
  ATMOSPHERE: (1250..1251) "\n"
  ATMOSPHERE: (1251..1252) ";"
  ATMOSPHERE: (1252..1253) "\n"
  ATMOSPHERE: (1253..1273) ";   (let ((temp #f))"
  ATMOSPHERE: (1273..1274) "\n"
  ATMOSPHERE: (1274..1308) ";     (if temp temp (my-or temp)))"
  ATMOSPHERE: (1308..1309) "\n"
  ATMOSPHERE: (1309..1310) ";"
  ATMOSPHERE: (1310..1311) "\n"
  ATMOSPHERE: (1311..1393) "; ...where the final `temp` would refer to the let-bound #f rather than the user's"
  ATMOSPHERE: (1393..1394) "\n"
  ATMOSPHERE: (1394..1474) "; `temp`, yielding #f.  A hygienic system renames the macro-introduced `temp` so"
  ATMOSPHERE: (1474..1475) "\n"
  ATMOSPHERE: (1475..1522) "; the user's `temp` is unaffected, yielding #t."
  ATMOSPHERE: (1522..1524) "\n\n"
  FORM: (1524..1540)
    OPEN_PAREN: (1524..1525) "("
    SYMBOL: (1525..1531)
