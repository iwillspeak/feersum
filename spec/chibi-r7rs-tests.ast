    ATMOSPHERE: (69636..69637) " "
    CONSTANT: (69637..69653)
      STRING: (69637..69653) "\"Numeric syntax\""
    CLOSE_PAREN: (69653..69654) ")"
  ATMOSPHERE: (69654..69656) "\n\n"
  ATMOSPHERE: (69656..69708) ";; ;; Numeric syntax adapted from Peter Bex's tests."
  ATMOSPHERE: (69708..69709) "\n"
  ATMOSPHERE: (69709..69714) ";; ;;"
  ATMOSPHERE: (69714..69715) "\n"
  ATMOSPHERE: (69715..69777) ";; ;; These are updated to R7RS, using string ports instead of"
  ATMOSPHERE: (69777..69778) "\n"
  ATMOSPHERE: (69778..69849) ";; ;; string->number, and \"error\" tests removed because implementations"
  ATMOSPHERE: (69849..69850) "\n"
  ATMOSPHERE: (69850..69920) ";; ;; are free to provide their own numeric extensions.  Currently all"
  ATMOSPHERE: (69920..69921) "\n"
  ATMOSPHERE: (69921..69986) ";; ;; tests are run by default - need to cond-expand and test for"
  ATMOSPHERE: (69986..69987) "\n"
  ATMOSPHERE: (69987..70013) ";; ;; infinities and -0.0."
  ATMOSPHERE: (70013..70015) "\n\n"
  ATMOSPHERE: (70015..70052) ";; (define-syntax test-numeric-syntax"
  ATMOSPHERE: (70052..70053) "\n"
  ATMOSPHERE: (70053..70074) ";;   (syntax-rules ()"
  ATMOSPHERE: (70074..70075) "\n"
  ATMOSPHERE: (70075..70124) ";;     ((test-numeric-syntax str expect strs ...)"
  ATMOSPHERE: (70124..70125) "\n"
  ATMOSPHERE: (70125..70174) ";;      (let* ((z (read (open-input-string str)))"
  ATMOSPHERE: (70174..70175) "\n"
  ATMOSPHERE: (70175..70216) ";;             (out (open-output-string))"
  ATMOSPHERE: (70216..70217) "\n"
  ATMOSPHERE: (70217..70286) ";;             (z-str (begin (write z out) (get-output-string out))))"
  ATMOSPHERE: (70286..70287) "\n"
  ATMOSPHERE: (70287..70321) ";;        (test expect (values z))"
  ATMOSPHERE: (70321..70322) "\n"
  ATMOSPHERE: (70322..70385) ";;        (test #t (and (member z-str '(str strs ...)) #t))))))"
  ATMOSPHERE: (70385..70387) "\n\n"
  ATMOSPHERE: (70387..70418) ";; ;; Each test is of the form:"
  ATMOSPHERE: (70418..70419) "\n"
  ATMOSPHERE: (70419..70424) ";; ;;"
  ATMOSPHERE: (70424..70425) "\n"
  ATMOSPHERE: (70425..70505) ";; ;;   (test-numeric-syntax input-str expected-value expected-write-values ...)"
  ATMOSPHERE: (70505..70506) "\n"
  ATMOSPHERE: (70506..70511) ";; ;;"
  ATMOSPHERE: (70511..70512) "\n"
  ATMOSPHERE: (70512..70579) ";; ;; where the input should be eqv? to the expected-value, and the"
  ATMOSPHERE: (70579..70580) "\n"
  ATMOSPHERE: (70580..70651) ";; ;; written output the same as any of the expected-write-values.  The"
  ATMOSPHERE: (70651..70652) "\n"
  ATMOSPHERE: (70652..70662) ";; ;; form"
  ATMOSPHERE: (70662..70663) "\n"
  ATMOSPHERE: (70663..70668) ";; ;;"
  ATMOSPHERE: (70668..70669) "\n"
  ATMOSPHERE: (70669..70723) ";; ;;   (test-numeric-syntax input-str expected-value)"
  ATMOSPHERE: (70723..70724) "\n"
  ATMOSPHERE: (70724..70729) ";; ;;"
  ATMOSPHERE: (70729..70730) "\n"
  ATMOSPHERE: (70730..70754) ";; ;; is a shorthand for"
  ATMOSPHERE: (70754..70755) "\n"
  ATMOSPHERE: (70755..70760) ";; ;;"
  ATMOSPHERE: (70760..70761) "\n"
  ATMOSPHERE: (70761..70827) ";; ;;   (test-numeric-syntax input-str expected-value (input-str))"
  ATMOSPHERE: (70827..70829) "\n\n"
  ATMOSPHERE: (70829..70841) ";; ;; Simple"
  ATMOSPHERE: (70841..70842) "\n"
  ATMOSPHERE: (70842..70872) ";; (test-numeric-syntax \"1\" 1)"
  ATMOSPHERE: (70872..70873) "\n"
  ATMOSPHERE: (70873..70908) ";; (test-numeric-syntax \"+1\" 1 \"1\")"
  ATMOSPHERE: (70908..70909) "\n"
  ATMOSPHERE: (70909..70941) ";; (test-numeric-syntax \"-1\" -1)"
  ATMOSPHERE: (70941..70942) "\n"
  ATMOSPHERE: (70942..70987) ";; (test-numeric-syntax \"#i1\" 1.0 \"1.0\" \"1.\")"
  ATMOSPHERE: (70987..70988) "\n"
  ATMOSPHERE: (70988..71033) ";; (test-numeric-syntax \"#I1\" 1.0 \"1.0\" \"1.\")"
  ATMOSPHERE: (71033..71034) "\n"
  ATMOSPHERE: (71034..71083) ";; (test-numeric-syntax \"#i-1\" -1.0 \"-1.0\" \"-1.\")"
  ATMOSPHERE: (71083..71084) "\n"
  ATMOSPHERE: (71084..71097) ";; ;; Decimal"
  ATMOSPHERE: (71097..71098) "\n"
  ATMOSPHERE: (71098..71143) ";; (test-numeric-syntax \"1.0\" 1.0 \"1.0\" \"1.\")"
