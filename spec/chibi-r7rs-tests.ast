  ATMOSPHERE: (23203..23205) "\n\n"
  ATMOSPHERE: (23205..23248) ";; ;; From R7RS 6.2.6 Numerical operations:"
  ATMOSPHERE: (23248..23249) "\n"
  ATMOSPHERE: (23249..23254) ";; ;;"
  ATMOSPHERE: (23254..23255) "\n"
  ATMOSPHERE: (23255..23308) ";; ;; These predicates are required to be transitive."
  ATMOSPHERE: (23308..23309) "\n"
  ATMOSPHERE: (23309..23314) ";; ;;"
  ATMOSPHERE: (23314..23315) "\n"
  ATMOSPHERE: (23315..23383) ";; ;; _Note:_ The traditional implementations of these predicates in"
  ATMOSPHERE: (23383..23384) "\n"
  ATMOSPHERE: (23384..23460) ";; ;; Lisp-like languages, which involve converting all arguments to inexact"
  ATMOSPHERE: (23460..23461) "\n"
  ATMOSPHERE: (23461..23522) ";; ;; numbers if any argument is inexact, are not transitive."
  ATMOSPHERE: (23522..23524) "\n\n"
  ATMOSPHERE: (23524..23554) ";; ;; Example from Alan Bawden"
  ATMOSPHERE: (23554..23555) "\n"
  ATMOSPHERE: (23555..23587) ";; (let ((a (- (expt 2 1000) 1))"
  ATMOSPHERE: (23587..23588) "\n"
  ATMOSPHERE: (23588..23658) ";;       (b (inexact (expt 2 1000))) ; assuming > single-float-epsilon"
  ATMOSPHERE: (23658..23659) "\n"
  ATMOSPHERE: (23659..23692) ";;       (c (+ (expt 2 1000) 1)))"
  ATMOSPHERE: (23692..23693) "\n"
  ATMOSPHERE: (23693..23732) ";;   (test #t (if (and (= a b) (= b c))"
  ATMOSPHERE: (23732..23733) "\n"
  ATMOSPHERE: (23733..23758) ";;                (= a c)"
  ATMOSPHERE: (23758..23759) "\n"
  ATMOSPHERE: (23759..23782) ";;                #t)))"
  ATMOSPHERE: (23782..23784) "\n\n"
  ATMOSPHERE: (23784..23829) ";; ;; From CLtL 12.3. Comparisons on Numbers:"
  ATMOSPHERE: (23829..23830) "\n"
  ATMOSPHERE: (23830..23835) ";; ;;"
  ATMOSPHERE: (23835..23836) "\n"
  ATMOSPHERE: (23836..23906) ";; ;;  Let _a_ be the result of (/ 10.0 single-float-epsilon), and let"
  ATMOSPHERE: (23906..23907) "\n"
  ATMOSPHERE: (23907..23977) ";; ;;  _j_ be the result of (floor a). ..., all of (<= a j), (< j (+ j"
  ATMOSPHERE: (23977..23978) "\n"
  ATMOSPHERE: (23978..24047) ";; ;;  1)), and (<= (+ j 1) a) would be true; transitivity would then"
  ATMOSPHERE: (24047..24048) "\n"
  ATMOSPHERE: (24048..24094) ";; ;;  imply that (< a a) ought to be true ..."
  ATMOSPHERE: (24094..24096) "\n\n"
  ATMOSPHERE: (24096..24140) ";; ;; Transliteration from Jussi Piitulainen"
  ATMOSPHERE: (24140..24141) "\n"
  ATMOSPHERE: (24141..24172) ";; (define single-float-epsilon"
  ATMOSPHERE: (24172..24173) "\n"
  ATMOSPHERE: (24173..24205) ";;   (do ((eps 1.0 (* eps 2.0)))"
  ATMOSPHERE: (24205..24206) "\n"
  ATMOSPHERE: (24206..24242) ";;       ((= eps (+ eps 1.0)) eps)))"
  ATMOSPHERE: (24242..24244) "\n\n"
  ATMOSPHERE: (24244..24287) ";; (let* ((a (/ 10.0 single-float-epsilon))"
  ATMOSPHERE: (24287..24288) "\n"
  ATMOSPHERE: (24288..24312) ";;        (j (exact a)))"
  ATMOSPHERE: (24312..24313) "\n"
  ATMOSPHERE: (24313..24359) ";;   (test #t (if (and (<= a j) (< j (+ j 1)))"
  ATMOSPHERE: (24359..24360) "\n"
  ATMOSPHERE: (24360..24398) ";;                (not (<= (+ j 1) a))"
  ATMOSPHERE: (24398..24399) "\n"
  ATMOSPHERE: (24399..24422) ";;                #t)))"
  ATMOSPHERE: (24422..24424) "\n\n"
