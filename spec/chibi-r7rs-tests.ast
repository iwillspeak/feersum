    ATMOSPHERE: (69497..69498) " "
    CONSTANT: (69498..69514)
      STRING: (69498..69514) "\"Numeric syntax\""
    CLOSE_PAREN: (69514..69515) ")"
  ATMOSPHERE: (69515..69517) "\n\n"
  ATMOSPHERE: (69517..69569) ";; ;; Numeric syntax adapted from Peter Bex's tests."
  ATMOSPHERE: (69569..69570) "\n"
  ATMOSPHERE: (69570..69575) ";; ;;"
  ATMOSPHERE: (69575..69576) "\n"
  ATMOSPHERE: (69576..69638) ";; ;; These are updated to R7RS, using string ports instead of"
  ATMOSPHERE: (69638..69639) "\n"
  ATMOSPHERE: (69639..69710) ";; ;; string->number, and \"error\" tests removed because implementations"
  ATMOSPHERE: (69710..69711) "\n"
  ATMOSPHERE: (69711..69781) ";; ;; are free to provide their own numeric extensions.  Currently all"
  ATMOSPHERE: (69781..69782) "\n"
  ATMOSPHERE: (69782..69847) ";; ;; tests are run by default - need to cond-expand and test for"
  ATMOSPHERE: (69847..69848) "\n"
  ATMOSPHERE: (69848..69874) ";; ;; infinities and -0.0."
  ATMOSPHERE: (69874..69876) "\n\n"
  ATMOSPHERE: (69876..69913) ";; (define-syntax test-numeric-syntax"
  ATMOSPHERE: (69913..69914) "\n"
  ATMOSPHERE: (69914..69935) ";;   (syntax-rules ()"
  ATMOSPHERE: (69935..69936) "\n"
  ATMOSPHERE: (69936..69985) ";;     ((test-numeric-syntax str expect strs ...)"
  ATMOSPHERE: (69985..69986) "\n"
  ATMOSPHERE: (69986..70035) ";;      (let* ((z (read (open-input-string str)))"
  ATMOSPHERE: (70035..70036) "\n"
  ATMOSPHERE: (70036..70077) ";;             (out (open-output-string))"
  ATMOSPHERE: (70077..70078) "\n"
  ATMOSPHERE: (70078..70147) ";;             (z-str (begin (write z out) (get-output-string out))))"
  ATMOSPHERE: (70147..70148) "\n"
  ATMOSPHERE: (70148..70182) ";;        (test expect (values z))"
  ATMOSPHERE: (70182..70183) "\n"
  ATMOSPHERE: (70183..70246) ";;        (test #t (and (member z-str '(str strs ...)) #t))))))"
  ATMOSPHERE: (70246..70248) "\n\n"
  ATMOSPHERE: (70248..70279) ";; ;; Each test is of the form:"
  ATMOSPHERE: (70279..70280) "\n"
  ATMOSPHERE: (70280..70285) ";; ;;"
  ATMOSPHERE: (70285..70286) "\n"
  ATMOSPHERE: (70286..70366) ";; ;;   (test-numeric-syntax input-str expected-value expected-write-values ...)"
  ATMOSPHERE: (70366..70367) "\n"
  ATMOSPHERE: (70367..70372) ";; ;;"
  ATMOSPHERE: (70372..70373) "\n"
  ATMOSPHERE: (70373..70440) ";; ;; where the input should be eqv? to the expected-value, and the"
  ATMOSPHERE: (70440..70441) "\n"
  ATMOSPHERE: (70441..70512) ";; ;; written output the same as any of the expected-write-values.  The"
  ATMOSPHERE: (70512..70513) "\n"
  ATMOSPHERE: (70513..70523) ";; ;; form"
  ATMOSPHERE: (70523..70524) "\n"
  ATMOSPHERE: (70524..70529) ";; ;;"
