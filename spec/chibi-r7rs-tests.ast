  ATMOSPHERE: (22690..22692) "\n\n"
  ATMOSPHERE: (22692..22735) ";; ;; From R7RS 6.2.6 Numerical operations:"
  ATMOSPHERE: (22735..22736) "\n"
  ATMOSPHERE: (22736..22741) ";; ;;"
  ATMOSPHERE: (22741..22742) "\n"
  ATMOSPHERE: (22742..22795) ";; ;; These predicates are required to be transitive."
  ATMOSPHERE: (22795..22796) "\n"
  ATMOSPHERE: (22796..22801) ";; ;;"
  ATMOSPHERE: (22801..22802) "\n"
  ATMOSPHERE: (22802..22870) ";; ;; _Note:_ The traditional implementations of these predicates in"
  ATMOSPHERE: (22870..22871) "\n"
  ATMOSPHERE: (22871..22947) ";; ;; Lisp-like languages, which involve converting all arguments to inexact"
  ATMOSPHERE: (22947..22948) "\n"
  ATMOSPHERE: (22948..23009) ";; ;; numbers if any argument is inexact, are not transitive."
  ATMOSPHERE: (23009..23011) "\n\n"
  ATMOSPHERE: (23011..23041) ";; ;; Example from Alan Bawden"
  ATMOSPHERE: (23041..23042) "\n"
  ATMOSPHERE: (23042..23074) ";; (let ((a (- (expt 2 1000) 1))"
  ATMOSPHERE: (23074..23075) "\n"
  ATMOSPHERE: (23075..23145) ";;       (b (inexact (expt 2 1000))) ; assuming > single-float-epsilon"
  ATMOSPHERE: (23145..23146) "\n"
  ATMOSPHERE: (23146..23179) ";;       (c (+ (expt 2 1000) 1)))"
  ATMOSPHERE: (23179..23180) "\n"
  ATMOSPHERE: (23180..23219) ";;   (test #t (if (and (= a b) (= b c))"
  ATMOSPHERE: (23219..23220) "\n"
  ATMOSPHERE: (23220..23245) ";;                (= a c)"
  ATMOSPHERE: (23245..23246) "\n"
  ATMOSPHERE: (23246..23269) ";;                #t)))"
  ATMOSPHERE: (23269..23271) "\n\n"
  ATMOSPHERE: (23271..23316) ";; ;; From CLtL 12.3. Comparisons on Numbers:"
  ATMOSPHERE: (23316..23317) "\n"
  ATMOSPHERE: (23317..23322) ";; ;;"
  ATMOSPHERE: (23322..23323) "\n"
  ATMOSPHERE: (23323..23393) ";; ;;  Let _a_ be the result of (/ 10.0 single-float-epsilon), and let"
  ATMOSPHERE: (23393..23394) "\n"
  ATMOSPHERE: (23394..23464) ";; ;;  _j_ be the result of (floor a). ..., all of (<= a j), (< j (+ j"
  ATMOSPHERE: (23464..23465) "\n"
  ATMOSPHERE: (23465..23534) ";; ;;  1)), and (<= (+ j 1) a) would be true; transitivity would then"
  ATMOSPHERE: (23534..23535) "\n"
  ATMOSPHERE: (23535..23581) ";; ;;  imply that (< a a) ought to be true ..."
  ATMOSPHERE: (23581..23583) "\n\n"
  ATMOSPHERE: (23583..23627) ";; ;; Transliteration from Jussi Piitulainen"
  ATMOSPHERE: (23627..23628) "\n"
  ATMOSPHERE: (23628..23659) ";; (define single-float-epsilon"
  ATMOSPHERE: (23659..23660) "\n"
  ATMOSPHERE: (23660..23692) ";;   (do ((eps 1.0 (* eps 2.0)))"
  ATMOSPHERE: (23692..23693) "\n"
  ATMOSPHERE: (23693..23729) ";;       ((= eps (+ eps 1.0)) eps)))"
  ATMOSPHERE: (23729..23731) "\n\n"
  ATMOSPHERE: (23731..23774) ";; (let* ((a (/ 10.0 single-float-epsilon))"
  ATMOSPHERE: (23774..23775) "\n"
  ATMOSPHERE: (23775..23799) ";;        (j (exact a)))"
  ATMOSPHERE: (23799..23800) "\n"
  ATMOSPHERE: (23800..23846) ";;   (test #t (if (and (<= a j) (< j (+ j 1)))"
  ATMOSPHERE: (23846..23847) "\n"
  ATMOSPHERE: (23847..23885) ";;                (not (<= (+ j 1) a))"
  ATMOSPHERE: (23885..23886) "\n"
  ATMOSPHERE: (23886..23909) ";;                #t)))"
