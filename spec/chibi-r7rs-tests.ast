  ATMOSPHERE: (23066..23109) ";; ;; From R7RS 6.2.6 Numerical operations:"
  ATMOSPHERE: (23109..23110) "\n"
  ATMOSPHERE: (23110..23115) ";; ;;"
  ATMOSPHERE: (23115..23116) "\n"
  ATMOSPHERE: (23116..23169) ";; ;; These predicates are required to be transitive."
  ATMOSPHERE: (23169..23170) "\n"
  ATMOSPHERE: (23170..23175) ";; ;;"
  ATMOSPHERE: (23175..23176) "\n"
  ATMOSPHERE: (23176..23244) ";; ;; _Note:_ The traditional implementations of these predicates in"
  ATMOSPHERE: (23244..23245) "\n"
  ATMOSPHERE: (23245..23321) ";; ;; Lisp-like languages, which involve converting all arguments to inexact"
  ATMOSPHERE: (23321..23322) "\n"
  ATMOSPHERE: (23322..23383) ";; ;; numbers if any argument is inexact, are not transitive."
  ATMOSPHERE: (23383..23385) "\n\n"
  ATMOSPHERE: (23385..23415) ";; ;; Example from Alan Bawden"
  ATMOSPHERE: (23415..23416) "\n"
  ATMOSPHERE: (23416..23448) ";; (let ((a (- (expt 2 1000) 1))"
  ATMOSPHERE: (23448..23449) "\n"
  ATMOSPHERE: (23449..23519) ";;       (b (inexact (expt 2 1000))) ; assuming > single-float-epsilon"
  ATMOSPHERE: (23519..23520) "\n"
  ATMOSPHERE: (23520..23553) ";;       (c (+ (expt 2 1000) 1)))"
  ATMOSPHERE: (23553..23554) "\n"
  ATMOSPHERE: (23554..23593) ";;   (test #t (if (and (= a b) (= b c))"
  ATMOSPHERE: (23593..23594) "\n"
  ATMOSPHERE: (23594..23619) ";;                (= a c)"
  ATMOSPHERE: (23619..23620) "\n"
  ATMOSPHERE: (23620..23643) ";;                #t)))"
  ATMOSPHERE: (23643..23645) "\n\n"
  ATMOSPHERE: (23645..23690) ";; ;; From CLtL 12.3. Comparisons on Numbers:"
  ATMOSPHERE: (23690..23691) "\n"
  ATMOSPHERE: (23691..23696) ";; ;;"
  ATMOSPHERE: (23696..23697) "\n"
  ATMOSPHERE: (23697..23767) ";; ;;  Let _a_ be the result of (/ 10.0 single-float-epsilon), and let"
  ATMOSPHERE: (23767..23768) "\n"
  ATMOSPHERE: (23768..23838) ";; ;;  _j_ be the result of (floor a). ..., all of (<= a j), (< j (+ j"
  ATMOSPHERE: (23838..23839) "\n"
  ATMOSPHERE: (23839..23908) ";; ;;  1)), and (<= (+ j 1) a) would be true; transitivity would then"
  ATMOSPHERE: (23908..23909) "\n"
  ATMOSPHERE: (23909..23955) ";; ;;  imply that (< a a) ought to be true ..."
  ATMOSPHERE: (23955..23957) "\n\n"
  ATMOSPHERE: (23957..24001) ";; ;; Transliteration from Jussi Piitulainen"
  ATMOSPHERE: (24001..24002) "\n"
  ATMOSPHERE: (24002..24033) ";; (define single-float-epsilon"
  ATMOSPHERE: (24033..24034) "\n"
  ATMOSPHERE: (24034..24066) ";;   (do ((eps 1.0 (* eps 2.0)))"
  ATMOSPHERE: (24066..24067) "\n"
  ATMOSPHERE: (24067..24103) ";;       ((= eps (+ eps 1.0)) eps)))"
  ATMOSPHERE: (24103..24105) "\n\n"
  ATMOSPHERE: (24105..24148) ";; (let* ((a (/ 10.0 single-float-epsilon))"
  ATMOSPHERE: (24148..24149) "\n"
  ATMOSPHERE: (24149..24173) ";;        (j (exact a)))"
  ATMOSPHERE: (24173..24174) "\n"
  ATMOSPHERE: (24174..24220) ";;   (test #t (if (and (<= a j) (< j (+ j 1)))"
  ATMOSPHERE: (24220..24221) "\n"
  ATMOSPHERE: (24221..24259) ";;                (not (<= (+ j 1) a))"
  ATMOSPHERE: (24259..24260) "\n"
  ATMOSPHERE: (24260..24283) ";;                #t)))"
  ATMOSPHERE: (24283..24285) "\n\n"
