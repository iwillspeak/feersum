  ATMOSPHERE: (77628..77629) "\n"
  ATMOSPHERE: (77629..77693) ";;                                      (get-output-string out))"
  ATMOSPHERE: (77693..77694) "\n"
  ATMOSPHERE: (77694..77736) ";;                                    \")\")"
  ATMOSPHERE: (77736..77737) "\n"
  ATMOSPHERE: (77737..77760) ";;          (pair? ls))"
  ATMOSPHERE: (77760..77761) "\n"
  ATMOSPHERE: (77761..77787) ";;        (when (pair? ls)"
  ATMOSPHERE: (77787..77788) "\n"
  ATMOSPHERE: (77788..77855) ";;          (test-assert (string-append \"(eqv?: \" str \" \" str2 \")\")"
  ATMOSPHERE: (77855..77856) "\n"
  ATMOSPHERE: (77856..77910) ";;            (eqv? n (string->number (car ls)))))))))"
