  ATMOSPHERE: (16727..16825) ";; < We fail this test because Hygiene is not enough to tell the two xs apart. Both _are_ the same"
  ATMOSPHERE: (16825..16846) "\n                    "
  ATMOSPHERE: (16846..16945) ";;   \"meaning\" of x (the free x in the root scope). Just the one in the template expansion of `foo`"
  ATMOSPHERE: (16945..16966) "\n                    "
  ATMOSPHERE: (16966..17062) ";;   is treated differently by syntax rules. We need to keep track of the provenance on a symbol"
  ATMOSPHERE: (17062..17083) "\n                    "
  ATMOSPHERE: (17083..17158) ";;   as well as the plain syntactic binding in order to tell the two apart."
  ATMOSPHERE: (17158..17160) "\n\n"
  ATMOSPHERE: (17160..17206) ";;; FIXME: Mutual recursion of `define` forms?"
