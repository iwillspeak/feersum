  ATMOSPHERE: (69542..69544) "\n\n"
  FORM: (69544..69573)
    OPEN_PAREN: (69544..69545) "("
    SYMBOL: (69545..69555)
      IDENTIFIER: (69545..69555) "test-begin"
    ATMOSPHERE: (69555..69556) " "
    CONSTANT: (69556..69572)
      STRING: (69556..69572) "\"Numeric syntax\""
    CLOSE_PAREN: (69572..69573) ")"
  ATMOSPHERE: (69573..69575) "\n\n"
  ATMOSPHERE: (69575..69627) ";; ;; Numeric syntax adapted from Peter Bex's tests."
  ATMOSPHERE: (69627..69628) "\n"
  ATMOSPHERE: (69628..69633) ";; ;;"
  ATMOSPHERE: (69633..69634) "\n"
  ATMOSPHERE: (69634..69696) ";; ;; These are updated to R7RS, using string ports instead of"
  ATMOSPHERE: (69696..69697) "\n"
  ATMOSPHERE: (69697..69768) ";; ;; string->number, and \"error\" tests removed because implementations"
  ATMOSPHERE: (69768..69769) "\n"
  ATMOSPHERE: (69769..69839) ";; ;; are free to provide their own numeric extensions.  Currently all"
  ATMOSPHERE: (69839..69840) "\n"
  ATMOSPHERE: (69840..69905) ";; ;; tests are run by default - need to cond-expand and test for"
  ATMOSPHERE: (69905..69906) "\n"
  ATMOSPHERE: (69906..69932) ";; ;; infinities and -0.0."
  ATMOSPHERE: (69932..69934) "\n\n"
  ATMOSPHERE: (69934..69971) ";; (define-syntax test-numeric-syntax"
  ATMOSPHERE: (69971..69972) "\n"
  ATMOSPHERE: (69972..69993) ";;   (syntax-rules ()"
  ATMOSPHERE: (69993..69994) "\n"
  ATMOSPHERE: (69994..70043) ";;     ((test-numeric-syntax str expect strs ...)"
  ATMOSPHERE: (70043..70044) "\n"
  ATMOSPHERE: (70044..70093) ";;      (let* ((z (read (open-input-string str)))"
  ATMOSPHERE: (70093..70094) "\n"
  ATMOSPHERE: (70094..70135) ";;             (out (open-output-string))"
  ATMOSPHERE: (70135..70136) "\n"
  ATMOSPHERE: (70136..70205) ";;             (z-str (begin (write z out) (get-output-string out))))"
  ATMOSPHERE: (70205..70206) "\n"
  ATMOSPHERE: (70206..70240) ";;        (test expect (values z))"
  ATMOSPHERE: (70240..70241) "\n"
  ATMOSPHERE: (70241..70304) ";;        (test #t (and (member z-str '(str strs ...)) #t))))))"
  ATMOSPHERE: (70304..70306) "\n\n"
  ATMOSPHERE: (70306..70337) ";; ;; Each test is of the form:"
  ATMOSPHERE: (70337..70338) "\n"
  ATMOSPHERE: (70338..70343) ";; ;;"
  ATMOSPHERE: (70343..70344) "\n"
  ATMOSPHERE: (70344..70424) ";; ;;   (test-numeric-syntax input-str expected-value expected-write-values ...)"
  ATMOSPHERE: (70424..70425) "\n"
  ATMOSPHERE: (70425..70430) ";; ;;"
  ATMOSPHERE: (70430..70431) "\n"
  ATMOSPHERE: (70431..70498) ";; ;; where the input should be eqv? to the expected-value, and the"
  ATMOSPHERE: (70498..70499) "\n"
  ATMOSPHERE: (70499..70570) ";; ;; written output the same as any of the expected-write-values.  The"
  ATMOSPHERE: (70570..70571) "\n"
  ATMOSPHERE: (70571..70581) ";; ;; form"
  ATMOSPHERE: (70581..70582) "\n"
  ATMOSPHERE: (70582..70587) ";; ;;"
  ATMOSPHERE: (70587..70588) "\n"
  ATMOSPHERE: (70588..70642) ";; ;;   (test-numeric-syntax input-str expected-value)"
  ATMOSPHERE: (70642..70643) "\n"
  ATMOSPHERE: (70643..70648) ";; ;;"
  ATMOSPHERE: (70648..70649) "\n"
  ATMOSPHERE: (70649..70673) ";; ;; is a shorthand for"
  ATMOSPHERE: (70673..70674) "\n"
  ATMOSPHERE: (70674..70679) ";; ;;"
  ATMOSPHERE: (70679..70680) "\n"
  ATMOSPHERE: (70680..70746) ";; ;;   (test-numeric-syntax input-str expected-value (input-str))"
  ATMOSPHERE: (70746..70748) "\n\n"
  ATMOSPHERE: (70748..70760) ";; ;; Simple"
  ATMOSPHERE: (70760..70761) "\n"
  ATMOSPHERE: (70761..70791) ";; (test-numeric-syntax \"1\" 1)"
  ATMOSPHERE: (70791..70792) "\n"
  ATMOSPHERE: (70792..70827) ";; (test-numeric-syntax \"+1\" 1 \"1\")"
  ATMOSPHERE: (70827..70828) "\n"
  ATMOSPHERE: (70828..70860) ";; (test-numeric-syntax \"-1\" -1)"
  ATMOSPHERE: (70860..70861) "\n"
  ATMOSPHERE: (70861..70906) ";; (test-numeric-syntax \"#i1\" 1.0 \"1.0\" \"1.\")"
  ATMOSPHERE: (70906..70907) "\n"
  ATMOSPHERE: (70907..70952) ";; (test-numeric-syntax \"#I1\" 1.0 \"1.0\" \"1.\")"
  ATMOSPHERE: (70952..70953) "\n"
  ATMOSPHERE: (70953..71002) ";; (test-numeric-syntax \"#i-1\" -1.0 \"-1.0\" \"-1.\")"
  ATMOSPHERE: (71002..71003) "\n"
  ATMOSPHERE: (71003..71016) ";; ;; Decimal"
  ATMOSPHERE: (71016..71017) "\n"
  ATMOSPHERE: (71017..71062) ";; (test-numeric-syntax \"1.0\" 1.0 \"1.0\" \"1.\")"
