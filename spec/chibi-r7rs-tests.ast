  ATMOSPHERE: (23075..23122) ";; (test '(#t #f) (list (<= 1 1 2) (<= 2 1 3)))"
  ATMOSPHERE: (23122..23124) "\n\n"
  ATMOSPHERE: (23124..23167) ";; ;; From R7RS 6.2.6 Numerical operations:"
  ATMOSPHERE: (23167..23168) "\n"
  ATMOSPHERE: (23168..23173) ";; ;;"
  ATMOSPHERE: (23173..23174) "\n"
  ATMOSPHERE: (23174..23227) ";; ;; These predicates are required to be transitive."
  ATMOSPHERE: (23227..23228) "\n"
  ATMOSPHERE: (23228..23233) ";; ;;"
  ATMOSPHERE: (23233..23234) "\n"
  ATMOSPHERE: (23234..23302) ";; ;; _Note:_ The traditional implementations of these predicates in"
  ATMOSPHERE: (23302..23303) "\n"
  ATMOSPHERE: (23303..23379) ";; ;; Lisp-like languages, which involve converting all arguments to inexact"
  ATMOSPHERE: (23379..23380) "\n"
  ATMOSPHERE: (23380..23441) ";; ;; numbers if any argument is inexact, are not transitive."
  ATMOSPHERE: (23441..23443) "\n\n"
  ATMOSPHERE: (23443..23473) ";; ;; Example from Alan Bawden"
  ATMOSPHERE: (23473..23474) "\n"
  ATMOSPHERE: (23474..23506) ";; (let ((a (- (expt 2 1000) 1))"
  ATMOSPHERE: (23506..23507) "\n"
  ATMOSPHERE: (23507..23577) ";;       (b (inexact (expt 2 1000))) ; assuming > single-float-epsilon"
  ATMOSPHERE: (23577..23578) "\n"
  ATMOSPHERE: (23578..23611) ";;       (c (+ (expt 2 1000) 1)))"
  ATMOSPHERE: (23611..23612) "\n"
  ATMOSPHERE: (23612..23651) ";;   (test #t (if (and (= a b) (= b c))"
  ATMOSPHERE: (23651..23652) "\n"
  ATMOSPHERE: (23652..23677) ";;                (= a c)"
  ATMOSPHERE: (23677..23678) "\n"
  ATMOSPHERE: (23678..23701) ";;                #t)))"
  ATMOSPHERE: (23701..23703) "\n\n"
  ATMOSPHERE: (23703..23748) ";; ;; From CLtL 12.3. Comparisons on Numbers:"
  ATMOSPHERE: (23748..23749) "\n"
  ATMOSPHERE: (23749..23754) ";; ;;"
  ATMOSPHERE: (23754..23755) "\n"
  ATMOSPHERE: (23755..23825) ";; ;;  Let _a_ be the result of (/ 10.0 single-float-epsilon), and let"
  ATMOSPHERE: (23825..23826) "\n"
  ATMOSPHERE: (23826..23896) ";; ;;  _j_ be the result of (floor a). ..., all of (<= a j), (< j (+ j"
  ATMOSPHERE: (23896..23897) "\n"
  ATMOSPHERE: (23897..23966) ";; ;;  1)), and (<= (+ j 1) a) would be true; transitivity would then"
  ATMOSPHERE: (23966..23967) "\n"
  ATMOSPHERE: (23967..24013) ";; ;;  imply that (< a a) ought to be true ..."
  ATMOSPHERE: (24013..24015) "\n\n"
  ATMOSPHERE: (24015..24059) ";; ;; Transliteration from Jussi Piitulainen"
  ATMOSPHERE: (24059..24060) "\n"
  ATMOSPHERE: (24060..24091) ";; (define single-float-epsilon"
  ATMOSPHERE: (24091..24092) "\n"
  ATMOSPHERE: (24092..24124) ";;   (do ((eps 1.0 (* eps 2.0)))"
  ATMOSPHERE: (24124..24125) "\n"
  ATMOSPHERE: (24125..24161) ";;       ((= eps (+ eps 1.0)) eps)))"
  ATMOSPHERE: (24161..24163) "\n\n"
  ATMOSPHERE: (24163..24206) ";; (let* ((a (/ 10.0 single-float-epsilon))"
  ATMOSPHERE: (24206..24207) "\n"
  ATMOSPHERE: (24207..24231) ";;        (j (exact a)))"
  ATMOSPHERE: (24231..24232) "\n"
  ATMOSPHERE: (24232..24278) ";;   (test #t (if (and (<= a j) (< j (+ j 1)))"
  ATMOSPHERE: (24278..24279) "\n"
  ATMOSPHERE: (24279..24317) ";;                (not (<= (+ j 1) a))"
  ATMOSPHERE: (24317..24318) "\n"
  ATMOSPHERE: (24318..24341) ";;                #t)))"
  ATMOSPHERE: (24341..24343) "\n\n"
