    ATMOSPHERE: (69123..69124) " "
    CONSTANT: (69124..69140)
      STRING: (69124..69140) "\"Numeric syntax\""
    CLOSE_PAREN: (69140..69141) ")"
  ATMOSPHERE: (69141..69143) "\n\n"
  ATMOSPHERE: (69143..69195) ";; ;; Numeric syntax adapted from Peter Bex's tests."
  ATMOSPHERE: (69195..69196) "\n"
  ATMOSPHERE: (69196..69201) ";; ;;"
  ATMOSPHERE: (69201..69202) "\n"
  ATMOSPHERE: (69202..69264) ";; ;; These are updated to R7RS, using string ports instead of"
  ATMOSPHERE: (69264..69265) "\n"
  ATMOSPHERE: (69265..69336) ";; ;; string->number, and \"error\" tests removed because implementations"
  ATMOSPHERE: (69336..69337) "\n"
  ATMOSPHERE: (69337..69407) ";; ;; are free to provide their own numeric extensions.  Currently all"
  ATMOSPHERE: (69407..69408) "\n"
  ATMOSPHERE: (69408..69473) ";; ;; tests are run by default - need to cond-expand and test for"
  ATMOSPHERE: (69473..69474) "\n"
  ATMOSPHERE: (69474..69500) ";; ;; infinities and -0.0."
  ATMOSPHERE: (69500..69502) "\n\n"
  ATMOSPHERE: (69502..69539) ";; (define-syntax test-numeric-syntax"
  ATMOSPHERE: (69539..69540) "\n"
  ATMOSPHERE: (69540..69561) ";;   (syntax-rules ()"
  ATMOSPHERE: (69561..69562) "\n"
  ATMOSPHERE: (69562..69611) ";;     ((test-numeric-syntax str expect strs ...)"
  ATMOSPHERE: (69611..69612) "\n"
  ATMOSPHERE: (69612..69661) ";;      (let* ((z (read (open-input-string str)))"
  ATMOSPHERE: (69661..69662) "\n"
  ATMOSPHERE: (69662..69703) ";;             (out (open-output-string))"
  ATMOSPHERE: (69703..69704) "\n"
  ATMOSPHERE: (69704..69773) ";;             (z-str (begin (write z out) (get-output-string out))))"
  ATMOSPHERE: (69773..69774) "\n"
  ATMOSPHERE: (69774..69808) ";;        (test expect (values z))"
  ATMOSPHERE: (69808..69809) "\n"
  ATMOSPHERE: (69809..69872) ";;        (test #t (and (member z-str '(str strs ...)) #t))))))"
  ATMOSPHERE: (69872..69874) "\n\n"
  ATMOSPHERE: (69874..69905) ";; ;; Each test is of the form:"
  ATMOSPHERE: (69905..69906) "\n"
  ATMOSPHERE: (69906..69911) ";; ;;"
  ATMOSPHERE: (69911..69912) "\n"
  ATMOSPHERE: (69912..69992) ";; ;;   (test-numeric-syntax input-str expected-value expected-write-values ...)"
  ATMOSPHERE: (69992..69993) "\n"
  ATMOSPHERE: (69993..69998) ";; ;;"
  ATMOSPHERE: (69998..69999) "\n"
  ATMOSPHERE: (69999..70066) ";; ;; where the input should be eqv? to the expected-value, and the"
  ATMOSPHERE: (70066..70067) "\n"
  ATMOSPHERE: (70067..70138) ";; ;; written output the same as any of the expected-write-values.  The"
  ATMOSPHERE: (70138..70139) "\n"
  ATMOSPHERE: (70139..70149) ";; ;; form"
  ATMOSPHERE: (70149..70150) "\n"
  ATMOSPHERE: (70150..70155) ";; ;;"
  ATMOSPHERE: (70155..70156) "\n"
  ATMOSPHERE: (70156..70210) ";; ;;   (test-numeric-syntax input-str expected-value)"
  ATMOSPHERE: (70210..70211) "\n"
  ATMOSPHERE: (70211..70216) ";; ;;"
  ATMOSPHERE: (70216..70217) "\n"
  ATMOSPHERE: (70217..70241) ";; ;; is a shorthand for"
  ATMOSPHERE: (70241..70242) "\n"
  ATMOSPHERE: (70242..70247) ";; ;;"
  ATMOSPHERE: (70247..70248) "\n"
  ATMOSPHERE: (70248..70314) ";; ;;   (test-numeric-syntax input-str expected-value (input-str))"
  ATMOSPHERE: (70314..70316) "\n\n"
  ATMOSPHERE: (70316..70328) ";; ;; Simple"
  ATMOSPHERE: (70328..70329) "\n"
  ATMOSPHERE: (70329..70359) ";; (test-numeric-syntax \"1\" 1)"
  ATMOSPHERE: (70359..70360) "\n"
  ATMOSPHERE: (70360..70395) ";; (test-numeric-syntax \"+1\" 1 \"1\")"
  ATMOSPHERE: (70395..70396) "\n"
  ATMOSPHERE: (70396..70428) ";; (test-numeric-syntax \"-1\" -1)"
  ATMOSPHERE: (70428..70429) "\n"
  ATMOSPHERE: (70429..70474) ";; (test-numeric-syntax \"#i1\" 1.0 \"1.0\" \"1.\")"
  ATMOSPHERE: (70474..70475) "\n"
  ATMOSPHERE: (70475..70520) ";; (test-numeric-syntax \"#I1\" 1.0 \"1.0\" \"1.\")"
  ATMOSPHERE: (70520..70521) "\n"
  ATMOSPHERE: (70521..70570) ";; (test-numeric-syntax \"#i-1\" -1.0 \"-1.0\" \"-1.\")"
  ATMOSPHERE: (70570..70571) "\n"
  ATMOSPHERE: (70571..70584) ";; ;; Decimal"
  ATMOSPHERE: (70584..70585) "\n"
  ATMOSPHERE: (70585..70630) ";; (test-numeric-syntax \"1.0\" 1.0 \"1.0\" \"1.\")"
  ATMOSPHERE: (70630..70631) "\n"
  ATMOSPHERE: (70631..70675) ";; (test-numeric-syntax \"1.\" 1.0 \"1.0\" \"1.\")"
  ATMOSPHERE: (70675..70676) "\n"
  ATMOSPHERE: (70676..70726) ";; (test-numeric-syntax \".1\" 0.1 \"0.1\" \"100.0e-3\")"
  ATMOSPHERE: (70726..70727) "\n"
  ATMOSPHERE: (70727..70781) ";; (test-numeric-syntax \"-.1\" -0.1 \"-0.1\" \"-100.0e-3\")"
  ATMOSPHERE: (70781..70782) "\n"
