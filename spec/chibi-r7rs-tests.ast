    ATMOSPHERE: (16830..16951) ";;  (test 'x (bar 1))  ;; < We fail this test because Hygiene is not enough to tell the two xs apart. Both _are_ the same"
    ATMOSPHERE: (16951..16952) "\n"
    ATMOSPHERE: (16952..17074) ";;                     ;;   \"meaning\" of x (the free x in the root scope). Just the one in the template expansion of `foo`"
    ATMOSPHERE: (17074..17075) "\n"
    ATMOSPHERE: (17075..17194) ";;                     ;;   is treated differently by syntax rules. We need to keep track of the provenance on a symbol"
    ATMOSPHERE: (17194..17195) "\n"
    ATMOSPHERE: (17195..17293) ";;                     ;;   as well as the plain syntactic binding in order to tell the two apart."
