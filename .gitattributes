# Set the default behavior, in case people don't have core.autocrlf set.
* text=auto

# Scheme files in our spec folder are line ending sensitive. Without this our
# specs would fail as diagnostics have different byte indices.
*.scm text eol=lf
*.sld text eol=lf

# AST snapshot files are generated with LF line endings and must not be
# converted to CRLF on Windows, otherwise snapshot comparison tests fail.
*.ast text eol=lf linguist-generated=true

# Verify snapshot files must use LF line endings for consistent comparison
*.verified.txt text eol=lf linguist-generated=true
