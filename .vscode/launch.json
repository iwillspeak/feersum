    "version": "0.2.0",
    "configurations": [
        {
            "name": "foob",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/src/fooble/bin/Debug/net5.0/fooble.dll",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": true,
            "console": "internalConsole"
        },
        {
            "name": "Iterfact",
            "type": "coreclr",
            "preLaunchTask": "builditerfact",
            "request": "launch",
            "program": "${workspaceFolder}/spec/bin/iterfact.dll",
            "args": [],
            "cwd": "${workspaceFolder}/spec/bin/",
            "stopAtEntry": true,
            "justMyCode": false,
            "console": "internalConsole",
            "requireExactSource": false,
            "internalConsoleOptions": "openOnSessionStart"
        },
        {
            "name": "Test Example",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/${input:dllToDebug}",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": true,
            "justMyCode": false,
            "console": "internalConsole",
            "requireExactSource": false,
            "internalConsoleOptions": "openOnSessionStart"
        },
        {
            "name": "Feersum",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceRoot}/src/Feersum/bin/Debug/netcoreapp3.1/Feersum.dll",
            "args": [],
            "cwd": "${workspaceRoot}",
            "console": "integratedTerminal",
            "stopAtEntry": false
        },
        {
            "name": "Dbg",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceRoot}/src/dbgdumper/bin/Debug/net5.0/dbgdumper.dll",
            "args": [ "${workspaceRoot}/src/fooble/bin/Debug/net5.0/fooble.dll" ],
            "cwd": "${workspaceRoot}",
            "console": "integratedTerminal",
            "stopAtEntry": true
        }
    ],
    "inputs": [
        {
            "type": "promptString",
            "description": "DLL to debug",
            "id": "dllToDebug"
        }
    ]
}